{
  // ================================================================
  // Profile: Software Engineer
  // Stack: TypeScript, React Native (Expo), Bun, ESLint + Prettier
  // ================================================================

  // ── Theme ────────────────────────────────────────────────────────
  "workbench.colorTheme": "Catppuccin Latte",
  "workbench.iconTheme": "catppuccin-latte",

  // ── Font: Fira Code Nerd Font ─────────────────────────────────────
  // Required for Starship prompt icons and font ligatures
  "editor.fontFamily": "FiraCode Nerd Font",
  "editor.fontSize": 14.5,
  "editor.lineHeight": 1.6,
  "editor.fontLigatures": true,
  "terminal.integrated.fontFamily": "FiraCode Nerd Font Mono",
  "terminal.integrated.fontSize": 13,

  // ── Terminal ─────────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.osx": "zsh",

  // ── ESLint + Prettier: JS/TS/React Linter + Formatter ────────────
  // ESLint runs Prettier as a rule via eslint-plugin-prettier;
  // the Prettier extension handles format-on-save.
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // ── Expo ─────────────────────────────────────────────────────────
  "files.associations": {
    "*.jsx": "javascriptreact",
    "*.tsx": "typescriptreact",
    "bun.lock": "yaml"
  },

  // ── Search and File Watcher ───────────────────────────────────────
  "search.exclude": {
    "**/node_modules": true,
    "**/.expo": true,
    "**/dist": true,
    "**/.next": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.expo/**": true,
    "**/dist/**": true
  },

  // ── Editor ───────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.inlayHints.enabled": "on",
  "editor.stickyScroll.enabled": true,
  "editor.minimap.enabled": false,
  "editor.rulers": [80, 88],
  "editor.renderWhitespace": "boundary",
  "workbench.editor.closeOnFileDelete": true,
  "workbench.editor.enablePreview": false,

  // ── YAML ─────────────────────────────────────────────────────────
  "yaml.format.enable": true,
  "yaml.validate": true,
  "[yaml]": {
    "editor.formatOnSave": true
  },

  // ── Privacy ──────────────────────────────────────────────────────
  "telemetry.telemetryLevel": "off",
  "workbench.enableExperiments": false,
  "extensions.autoCheckUpdates": false,
  "update.mode": "none"
}
